<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Avalonia_BVE5_Motor_Assistance.Controls.TitleBar">

		<Grid Height="60" Background="#303942">
			<TextBlock Text="BVE5 Motor Assistance" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontFamily="{StaticResource Dosis}" FontWeight="Bold"/>
			<StackPanel VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Right">
				<Button Cursor="Hand" Click="Min_Button_Click">
					<Image Source="avares://Avalonia-BVE5-Motor-Assistance/Assets/Buttons/min.png"/>
				</Button>
				<Button Cursor="Hand" Click="Max_Button_Click">
					<Image Source="avares://Avalonia-BVE5-Motor-Assistance/Assets/Buttons/max.png"/>
				</Button>
				<Button Cursor="Hand" Click="Close_Button_Click">
					<Image Source="avares://Avalonia-BVE5-Motor-Assistance/Assets/Buttons/close.png" />
				</Button>
			</StackPanel>
		</Grid>
</UserControl>
