<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ct="clr-namespace:BVE5_Motor_Assistance.Control">
    <Style TargetType="{x:Type ct:FButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ct:FButton}">
                    <Border  CornerRadius="2" BorderBrush="White" BorderThickness="1" Background="#495159">
                        <Grid x:Name="buttonGrid" Cursor="Hand">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}" FontSize="{TemplateBinding FontSize}" VerticalAlignment="Center" TextAlignment="Center"/>
                        </Grid>
                    </Border>

                </ControlTemplate>


            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>